PORT=8787
VITE_API_URL=http://localhost:8787

# Public browser-safe Supabase values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Server-only Supabase values
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared AI providers, server-only
SHARED_GEMINI_API_KEY=your-gemini-key
SHARED_GEMINI_MODEL=gemini-2.5-flash
SHARED_GROQ_API_KEY=
SHARED_GROQ_MODEL=llama-3.1-8b-instant
SHARED_OPENROUTER_API_KEY=
SHARED_OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
SHARED_OPENAI_API_KEY=
SHARED_OPENAI_MODEL=gpt-4.1-mini

# Provider reliability and daily quota
PROVIDER_TIMEOUT_MS=12000
SHARED_AI_DAILY_REQUEST_LIMIT=30
SHARED_AI_DAILY_TOKEN_LIMIT=60000
SHARED_AI_LIMIT_EXEMPT_EMAILS=
SHARED_AI_QUOTA_FAIL_OPEN=false

# Free daily automation with Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
DAILY_NEWS_CRON_SECRET=change-this-long-random-secret

# Optional legacy WhatsApp fallback
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=
TWILIO_CONTENT_SID=
TWILIO_CONTENT_VARIABLES=

# Coder safety
CODER_EXECUTION_MODE=draft_only
CODER_SANDBOX_DIR=.coder-sandbox
CODER_PACKAGE_ALLOWLIST=
